# ==============================
# Project Configuration (EDIT THESE)
# ==============================

# Compiler
CXX = g++

# Compiler flags
CXXFLAGS = -Wall -Wextra -std=c++17 -g

# Executable names
APP     = app
TESTAPP = tests

# Source files (ADD .cpp FILES HERE)
SRC     = main.cpp
TESTSRC = tests.cpp

# Project info (for tarball submission)
PROJECT = project-name
VERSION = 1.0

# ==============================
# Derived Values (NO EDITING NEEDED)
# ==============================

OBJS     = $(SRC:.cpp=.o)
TESTOBJS = $(TESTSRC:.cpp=.o)

.PHONY: all clean run runtests edit session dist valgrind valgrind-tests

# ==============================
# Build Targets
# ==============================

all: $(APP)

$(APP): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

$(TESTAPP): $(TESTOBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

# Compile source files into object files
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $<

# ==============================
# Run Targets
# ==============================

run: $(APP)
	./$(APP)

runtests: $(TESTAPP)
	./$(TESTAPP)

# ==============================
# Memory Checking (Valgrind)
# ==============================

valgrind: $(APP)
	valgrind --leak-check=full \
		--show-leak-kinds=all \
		--track-origins=yes \
		./$(APP)

valgrind-tests: $(TESTAPP)
	valgrind --leak-check=full \
		--show-leak-kinds=all \
    --track-origins=yes \
    ./$(TESTAPP)

# ==============================
# Distribution (Tarball)
# ==============================

dist:
	tar -czf $(PROJECT)-$(VERSION).tar.gz \
		Makefile *.cpp *.h README* 2>/dev/null

# ==============================
# Vim Helpers
# ==============================

edit:
	@if [ -f .vim/session.vim ]; then \
		vim -S .vim/session.vim; \
	else \
		vim -p *.cpp *.h; \
	fi

session:
	@mkdir -p .vim
	@vim +'mksession! .vim/session.vim' +qa

# ==============================
# Cleanup
# ==============================

clean:
	rm -f *.o $(APP) $(TESTAPP) *.tar.gz
