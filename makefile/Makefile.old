# ==============================
# Project Configuration (EDIT THESE)
# ==============================

# Compiler
CXX = g++

# Compiler flags
CXXFLAGS = -Wall -Wextra -std=c++17 -g

# Executable names
APP     = app
TESTAPP = tests

# Source files (ADD .cpp FILES HERE)
SRC     = main.cpp
TESTSRC = tests.cpp

# Project info (for tarball submission)
PROJECT = project-name
VERSION = 1.0

DISTFILES := Makefile \
						 $(wildcard *.cpp) \
						 $(wildcard *.h) \
						 $(wildcard README*)

# ==============================
# Derived Values (NO EDITING NEEDED)
# ==============================

OBJS     		= $(SRC:.cpp=.o)
TESTOBJS 		= $(TESTSRC:.cpp=.o)

# Header files (exclude main.h by default)
HDRS	 	 		= $(filter-out main.h, $(SRC:.cpp=.h))

# All expected source files
ALLSRC	 		= $(SRC) $(TESTSRC)

# Vim & Git setup
VIM_DIR	 		= .vim
VIM_SESSION	= $(VIM_DIR)/session.vim
GITIGNORE		= .gitignore


.PHONY: all clean run runtests edit dist valgrind valgrind-tests setup SETUP

# ==============================
# Build Targets
# ==============================

all: $(APP)

$(APP): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

$(TESTAPP): $(TESTOBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

# Compile source files into object files
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $<

#===============================
# Setup Target
#===============================
SETUP: setup
setup: $(ALLSRC) $(HDRS) $(VIM_SESSION) $(GITIGNORE)
	@echo -e " \u2714 Project setup completed!"

#-------------------------------
# Auto-create missing .cpp files
#-------------------------------
%.cpp:
	@echo "Creating source $@"
	@printf "%s\n" \
		"#include \"$(basename $@).h\"" \
		""\
		> $@


#-------------------------------
# Auto-create matching .h files
#-------------------------------
%.h:
	@echo "Creating head $@"
	@printf "%s\n" \
		"#ifndef '$(basename $@)_H'" \
		"#define '$(basename $@)_H'" \
		"" \
		"" \
		"class $(basename $@) {" \
		"Public: " \
		"" \
		"Private: " \
		"" \
		"};" \
		"" \
		"// Declarations for $(basename $@)" \
    "#endif" \
    > $@

#-------------------------------
# Vim session file
#-------------------------------
$(VIM_SESSION):
	@echo "Creating $(VIM_SESSION)"
	@mkdir -p $(VIM_DIR)
	$@


#-------------------------------
# .gitignore
#-------------------------------
$(GITIGNORE):
	@echo "Creating .gitignore"
	@printf "%s/n" \
		"*.o" \
		"*.out" \
		"$(APP)" \
		"$(TESTAPP)" \
		"*.tar.gz" \
		"$(VIM_DIR)/" \
		> $@


# ==============================
# Run Targets
# ==============================

run: $(APP)
	./$(APP)

runtests: $(TESTAPP)
	./$(TESTAPP)

# ==============================
# Memory Checking (Valgrind)
# ==============================

valgrind: $(APP)
	valgrind --leak-check=full \
		--show-leak-kinds=all \
		--track-origins=yes \
		./$(APP)

valgrind-tests: $(TESTAPP)
	valgrind --leak-check=full \
		--show-leak-kinds=all \
    --track-origins=yes \
    ./$(TESTAPP)

# ==============================
# Distribution (Tarball)
# ==============================

dist:
	tar -czf $(PROJECT)-$(VERSION).tar.gz \
		$(DISTFILES)

# ==============================
# Vim Helpers
# ==============================

edit:
	@if [ -f .vim/session.vim ]; then \
		vim -S .vim/session.vim; \
	else \
		vim -p *.cpp *.h; \
	fi

# ==============================
# Cleanup
# ==============================

clean:
	rm -f *.o $(APP) $(TESTAPP) *.tar.gz
